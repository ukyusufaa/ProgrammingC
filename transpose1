#include <stdio.h>

int main(){
    int i,j;
    int number[3][2]={
        {5,2},
        {1,8},
        {6,9}
    };
    int transpose[2][3];

    for(i=0;i<3;i++){
        for(j=0;j<2;j++){
            transpose[j][i]=number[i][j];
        }
    }
    for(i=0;i<2;i++){
        for(j=0;j<3;j++){
            printf("%d",transpose[i][j]);
        }
        printf("\n");
    }

    return 0;
}